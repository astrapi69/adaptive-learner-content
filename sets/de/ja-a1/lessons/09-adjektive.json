        "prompt": "Wie heißt 'klein' auf Japanisch?",
        "card_ids": ["chiisai"],
        "accept": ["小さい", "chiisai", "ちいさい"],
        "hint": "Gegenteil von 大きい (groß).",
        "distractors": ["大きい", "新しい", "古い"],
        "direction": "source_to_target"
      }
    },
    {
