        "type": "matching",
        "prompt": "Ordne jedes portugiesische Wort der deutschen Bedeutung zu.",
        "card_ids": ["o-cardapio", "a-conta", "agua", "o-garcom", "suco"],
        "pairs": [
          {"left": "o cardápio", "right": "die Speisekarte"},
          {"left": "a conta", "right": "die Rechnung"},
          {"left": "água", "right": "Wasser"},
          {"left": "o garçom", "right": "der Kellner"},
          {"left": "suco", "right": "Saft"}
        ],
        "direction": "target_to_source"
      }
    },
