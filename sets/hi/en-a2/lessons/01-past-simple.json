        "prompt": "Match each English past-tense verb with its Hindi meaning.",
        "card_ids": ["en-a2-played", "en-a2-went", "en-a2-ate", "en-a2-bought"],
        "pairs": [
          {"left": "played", "right": "खेला"},
          {"left": "went", "right": "गया / गई"},
          {"left": "ate", "right": "खाया"},
          {"left": "bought", "right": "खरीदा"}
        ],
        "direction": "target_to_source"
      }
    },
    {
