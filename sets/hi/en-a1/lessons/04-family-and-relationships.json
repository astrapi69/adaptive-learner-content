        "type": "free_text",
        "prompt": "Translate to English: बहन",
        "card_ids": [
          "hi-sister"
        ],
        "accept": [
          "Sister",
          "sister"
        ],
        "distractors": [
          "Brother",
          "Mother",
          "Daughter"
        ],
        "hint": "A female sibling.",
        "direction": "source_to_target"
      }
    },
    {
      "id": "l4-ex-cloze-son",
      "type": "exercise",
      "title": "Complete the sentence",
      "exercise": {
        "id": "l4-ex-cloze-son",
        "type": "cloze",
        "prompt": "Fill the blank in English.",
        "card_ids": [
          "hi-son"
        ],
        "sentence": "This is my ___ . (यह मेरा बेटा है।)",
        "blanks": [
