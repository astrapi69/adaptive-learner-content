        "prompt": "Match each German word with its English meaning.",
        "card_ids": ["de-a2-links", "de-a2-rechts", "de-a2-geradeaus", "de-a2-entschuldigung"],
        "pairs": [
          {"left": "links", "right": "(on the) left"},
          {"left": "rechts", "right": "(on the) right"},
          {"left": "geradeaus", "right": "straight ahead"},
          {"left": "Entschuldigung", "right": "excuse me / sorry"}
        ],
        "direction": "target_to_source"
      }
    },
