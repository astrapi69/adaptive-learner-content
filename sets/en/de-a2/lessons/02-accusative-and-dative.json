        "card_ids": ["de-a2-ich-gebe-dem-kind"],
        "tiles": ["Ich", "gebe", "dem", "Kind", "den", "Ball"],
        "hint": "Receiver (dative) before the thing given (accusative).",
        "direction": "source_to_target"
      }
    },
    {
