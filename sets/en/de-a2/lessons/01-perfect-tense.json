        "prompt": "Complete: \"I ate pizza.\"",
        "card_ids": ["de-a2-habe-gemacht", "de-a2-gegessen"],
        "sentence": "Ich ___ Pizza gegessen.",
        "blanks": [{"accept": ["habe"]}],
        "cloze_mode": "type",
        "hint": "*essen* takes haben."
      }
    },
    {
      "id": "l1-ex-cloze-sein",
      "type": "exercise",
      "theory_ref": "l1-perfekt-theory",
      "title": "Choose the right helper (sein)",
      "exercise": {
        "id": "l1-ex-cloze-sein",
        "type": "cloze",
        "prompt": "Complete: \"We went to Berlin.\"",
        "card_ids": ["de-a2-bin-gegangen", "de-a2-gefahren"],
        "sentence": "Wir ___ nach Berlin gefahren.",
        "blanks": [{"accept": ["sind"]}],
        "cloze_mode": "type",
        "hint": "*fahren* is movement, so it takes sein. \"We\" = wir."
      }
    },
